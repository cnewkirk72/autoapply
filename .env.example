# ---- Supabase ----
# Create a project at https://supabase.com -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...        # SERVER ONLY. Never expose to the browser.

# ---- Anthropic (Claude) ----
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- OpenAI (embeddings only) ----
# https://platform.openai.com
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- SerpAPI (job board scraping) ----
# https://serpapi.com — recommended primary source for Phase 1
SERPAPI_KEY=

# ---- Optional: Playwright worker ----
# When PLAYWRIGHT_ENABLED=true the Railway worker will attempt direct scrapes
# before falling back to SerpAPI. Leave blank/false for Phase 1.
PLAYWRIGHT_ENABLED=false
PROXY_URL=

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
