# ---- Supabase ----
# Create a project at https://supabase.com -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...        # SERVER ONLY. Never expose to the browser.

# ---- Anthropic (Claude) ----
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- OpenAI (embeddings only) ----
# Used solely for text-embedding-3-small to power pgvector similarity.
# Easy to swap for Voyage / Cohere later — see lib/openai.ts.
# https://platform.openai.com
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Brave Search (job discovery layer) ----
# https://brave.com/search/api/  — free tier: 2,000 queries/mo
# Brave finds job posting URLs across LinkedIn, Indeed, Greenhouse, Lever,
# Wellfound, Ashby, etc. Firecrawl then extracts the structured fields.
BRAVE_API_KEY=

# ---- Firecrawl (job extraction layer) ----
# https://firecrawl.dev  — hobby tier: $16/mo for 3,000 credits
# Each job posting URL = 1 scrape credit. Used with JSON Schema to pull
# title, company, location, salary, description from arbitrary job boards.
FIRECRAWL_API_KEY=fc-...

# ---- Optional: Playwright worker (Phase 2) ----
# When PLAYWRIGHT_ENABLED=true the Railway worker will attempt direct scrapes
# as a fallback / supplement to the Brave + Firecrawl pipeline.
PLAYWRIGHT_ENABLED=false
PROXY_URL=

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
